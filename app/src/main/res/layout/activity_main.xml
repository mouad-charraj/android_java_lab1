<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout personnalisé par Mouad Charraj
    Application de compteur simple et élégante
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/layout_principal_mouad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Compteur de score -->
        <TextView
            android:id="@+id/affichage_chiffre_mouad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/valeur_depart"
            android:textColor="#263238"
            android:textSize="90sp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp" />

        <!-- Bouton Salutations -->
        <Button
            android:id="@+id/btn_dire_salut_mouad"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:text="@string/btn_salutation"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Bouton Incrémenter -->
        <Button
            android:id="@+id/btn_incrementeur_mouad"
            android:layout_width="220dp"
            android:layout_height="60dp"
            android:text="@string/btn_ajouter"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Signature de l'auteur -->
    <TextView
        android:id="@+id/signature_auteur_mouad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/signature_mouad"
        android:textColor="#90A4AE"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>